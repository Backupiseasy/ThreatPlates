std = "lua51"
max_line_length = false

exclude_files = {
  "Libs/**",
  "Test/**",
  "Source/**",
  ".release/**"
}

globals = {
  "TidyPlatesThreat",
  "TidyPlatesThreatDBM",
  "TidyPlatesThreat_OnAddonCompartmentClick",
  "SLASH_TPTPDPS1",
  "SLASH_TPTPTANK1",
  "SLASH_TPTPTOGGLE1",
  "SLASH_TPTPOVERLAP1",
  "SLASH_TPTPVERBOSE1",
  "SlashCmdList",
  "StaticPopupDialogs"
}

-- Keep CI gating focused on accidental global writes.
only = {"111", "112"}
